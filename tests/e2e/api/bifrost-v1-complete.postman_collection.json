              "raw": "{{base_url}}/v1/files?x-model-provider={{provider}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "files"],
              "query": [{"key": "x-model-provider", "value": "{{provider}}"}]
            }
          }
        },
        {
          "name": "Retrieve File",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var provider = pm.collectionVariables.get('provider') || pm.variables.get('provider') || (pm.environment && pm.environment.get('provider')) || '';",
                  "var fileId = pm.collectionVariables.get('file_id') || pm.variables.get('file_id') || (pm.environment && pm.environment.get('file_id')) || '';",
                  "if (provider === 'bedrock' && (!fileId || fileId === 'file_123' || !/^s3:\\/\\//.test(fileId))) { postman.setNextRequest('Get File Content'); }"
                ],
                "type": "text/javascript"
