                  "key": "file",
                  "type": "file",
                  "src": "{{batch_file}}"
                },
                {
                  "key": "purpose",
                  "value": "batch",
                  "type": "text"
                },
                {
                  "key": "provider",
                  "value": "{{provider}}",
                  "type": "text"
                }
              ]
            },
            "url": {
