            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/files/{{file_id}}?provider={{provider}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "files", "{{file_id}}"],
              "query": [{"key": "provider", "value": "{{provider}}"}]
            }
          }
        },
