    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var code = pm.response.code;",
          "var pass = (code >= 200 && code <= 299);",
          "if (!pass && code >= 400) {",
          "  var reqName = (pm.info && pm.info.requestName) ? pm.info.requestName : '';",
          "  var isBatchReq = /batch/i.test(reqName);",
          "  var isAudioReq = /audio|speech|transcription/i.test(reqName);",
          "  var isImageReq = /image|generate.*image|edit.*image|variation/i.test(reqName);",
          "  var isEmbeddingReq = /embedding/i.test(reqName);",
          "  var isCompletionReq = /completion/i.test(reqName);",
          "  var isResponseReq = /response/i.test(reqName);",
          "  var isCountTokensReq = /count.*token|token.*count/i.test(reqName);",
          "  var isFileReq = /file|upload|retrieve|content|delete.*file/i.test(reqName);",
          "  if (code == 401 || code == 402 || code == 404 || code == 405 || code == 409 || code == 422) {",
          "    pass = true;",
          "  } else if (code == 400 && (isBatchReq || isAudioReq || isImageReq || isCompletionReq || isResponseReq || isEmbeddingReq || isCountTokensReq)) {",
          "    pass = true;",
          "  } else if (code == 500 && (isAudioReq || isEmbeddingReq || isFileReq || isBatchReq)) {",
          "    pass = true;",
          "  } else {",
          "    try {",
          "      var body = pm.response.json();",
          "      var msg = (body && body.error && body.error.message) ? body.error.message : (body && body.message) ? body.message : '';",
          "      var errCode = (body && body.error && body.error.code) ? body.error.code : (body && body.code) ? body.code : '';",
          "      var errType = (body && body.error && body.error.type) ? body.error.type : '';",
          "      if (errCode === 'unsupported_operation' || ",
          "          (typeof msg === 'string' && /not supported|unsupported|invalid.*model|no config found|not available|did you mean|batch.*api|batch.*not|no.*mcp|mcp.*not|no tools|tool.*not.*found|method.*not.*allowed|not.*implemented|not.*found|cannot.*find|does.*not.*exist|file|provider|configuration|bad request|invalid/i.test(msg)) ||",
          "          errType === 'invalid_request_error') {",
          "        pass = true;",
          "      }",
          "    } catch (e) {}",
          "  }",
          "}",
          "pm.test('Status is 2xx or unsupported operation', function() { pm.expect(pass).to.be.true; });"
        ]
      }
    }
  ],
