{
  "info": {
    "name": "Bifrost V1 API - Complete",
    "description": "Complete Postman collection for all Bifrost /v1 endpoints with valid payloads",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var requestName = pm.info.requestName;",
          "var retryKey = 'retry_' + requestName;",
          "var ciVal = pm.environment.get('CI');",
          "var maxRetries = (ciVal === '1' || ciVal === 1) ? 3 : 0;",
          "if (!pm.collectionVariables.has(retryKey)) {",
          "  pm.collectionVariables.set(retryKey, 0);",
          "}",
          "pm.collectionVariables.set('current_request_name', requestName);",
          "pm.collectionVariables.set('max_retries', maxRetries);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var code = pm.response.code;",
          "var reqName = (pm.info && pm.info.requestName) ? pm.info.requestName : '';",
          "var isBatchReq = /batch/i.test(reqName);",
          "var isAudioReq = /audio|speech|transcription/i.test(reqName);",
          "var isImageReq = /image|generate.*image|edit.*image|variation/i.test(reqName);",
          "var isEmbeddingReq = /embedding/i.test(reqName);",
          "var isCompletionReq = /completion/i.test(reqName);",
          "var isResponseReq = /response/i.test(reqName);",
          "var isCountTokensReq = /count.*token|token.*count/i.test(reqName);",
          "var isFileReq = /file|upload|retrieve|content|delete.*file/i.test(reqName);",
          "var isContainerReq = /container/i.test(reqName);",
          "var isMcpReq = /mcp|execute.*tool/i.test(reqName);",
          "var isListModelsReq = /list.*models|models.*list/i.test(reqName);",
          "var isContainerPurposeFileReq = (reqName === 'Upload File (for container reference)' || reqName === 'Create Container File (Reference)');",
          "var isAllowedUnsupported = isBatchReq || isAudioReq || isImageReq || isEmbeddingReq || isCompletionReq || isResponseReq || isCountTokensReq || isFileReq || isContainerReq || isMcpReq || isListModelsReq || isContainerPurposeFileReq;",
          "var allowedCodes = (code === 402 || code === 405 || code === 409 || code === 422);",
          "var whitelistedMessage = false;",
          "try {",
          "  var body = pm.response.json();",
          "  var msg = (body && body.error && body.error.message) ? body.error.message : (body && body.message) ? body.message : '';",
          "  var errCode = (body && body.error && body.error.code) ? body.error.code : (body && body.code) ? body.code : '';",
          "  whitelistedMessage = (errCode === 'unsupported_operation') ||",
          "    (typeof msg === 'string' && /not supported on this API|use the Messages API instead|please use the Messages API|method not allowed|not implemented|batch.*(not )?supported|batch results not available|no available results|no batch-enabled keys found|no config found for batch APIs|requests array is required for Anthropic batch API|no .*mcp|mcp .*not (enabled|available)|tool.*not found|tool.*not available|not available or not permitted|no tools (available|configured)|no config found|not available (for|on)|container.*not supported|by reference.*not supported|did you mean|file is required|multipart file upload required|not found|only files created by|file content|content.*not.*(available|supported)|download.*not supported|not downloadable|list.*model|model.*list|models.*not supported|list_models|please adjust your prompt/i.test(msg));",
          "} catch (e) {}",
          "var isDocumentedUnsupported = isAllowedUnsupported && (allowedCodes || ((code === 400 || code === 404 || code === 500) && whitelistedMessage));",
          "if (code >= 200 && code <= 299) {",
          "  pm.test('Status is 2xx', function() { pm.expect(code >= 200 && code <= 299).to.be.true; });",
          "} else {",
          "  pm.test('Or documented unsupported (allowed request types)', function() {",
          "    pm.expect(isDocumentedUnsupported, 'Non-2xx response must be a documented unsupported error for this request type').to.be.true;",
          "  });",
          "}",
          "var requestNameRetry = pm.collectionVariables.get('current_request_name');",
          "var retryKey = 'retry_' + requestNameRetry;",
          "var currentRetry = pm.collectionVariables.get(retryKey) || 0;",
          "var maxRetries = pm.collectionVariables.get('max_retries') || 0;",
          "var failedTests = code < 200 || code > 299;",
          "var hasFailures = failedTests && !isDocumentedUnsupported;",
          "if (hasFailures && maxRetries > 0 && currentRetry < maxRetries) {",
          "  pm.collectionVariables.set(retryKey, currentRetry + 1);",
          "  console.log('[RETRY] Request \"' + requestNameRetry + '\" failed (attempt ' + (currentRetry + 1) + '/' + maxRetries + '). Retrying...');",
          "  postman.setNextRequest(requestNameRetry);",
          "} else {",
          "  pm.collectionVariables.set(retryKey, 0);",
          "  if (hasFailures && currentRetry >= maxRetries && maxRetries > 0) {",
          "    console.log('[RETRY] Request \"' + requestNameRetry + '\" failed after ' + maxRetries + ' retries. Moving on.');",
          "  }",
          "}"
        ]
      }
    }
  ],
