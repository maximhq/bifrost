      "value": "{\"description\":\"Provider capability matrix for integration tests. Lists operation categories unsupported per provider. Used to skip requests when running with all provider envs.\",\"operation_categories\":[\"batch\",\"file\",\"container\",\"embedding\",\"speech\",\"transcription\",\"image\"],\"providers\":{\"openai\":{\"unsupported\":[]},\"anthropic\":{\"unsupported\":[\"embedding\",\"speech\",\"transcription\",\"image\",\"container\"]},\"azure\":{\"unsupported\":[\"transcription\",\"image\",\"container\"]},\"bedrock\":{\"unsupported\":[\"speech\",\"transcription\",\"image\",\"container\"]},\"cerebras\":{\"unsupported\":[\"batch\",\"file\",\"container\",\"embedding\",\"speech\",\"transcription\",\"image\"]},\"cohere\":{\"unsupported\":[\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]},\"elevenlabs\":{\"unsupported\":[\"batch\",\"file\",\"container\",\"embedding\",\"image\",\"transcription\"]},\"gemini\":{\"unsupported\":[\"container\",\"image\"]},\"groq\":{\"unsupported\":[\"embedding\",\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]},\"huggingface\":{\"unsupported\":[\"batch\",\"file\",\"container\",\"image\"]},\"mistral\":{\"unsupported\":[\"speech\",\"image\",\"batch\",\"file\",\"container\"]},\"nebius\":{\"unsupported\":[\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]},\"openrouter\":{\"unsupported\":[\"embedding\",\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]},\"parasail\":{\"unsupported\":[\"embedding\",\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]},\"perplexity\":{\"unsupported\":[\"embedding\",\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]},\"vertex\":{\"unsupported\":[\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]},\"xai\":{\"unsupported\":[\"embedding\",\"speech\",\"transcription\",\"image\",\"batch\",\"file\",\"container\"]}}}",
